<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Directorio de IAs: Gratis • Trial • Pagas</title>
  <style>
    :root {
      --bg: #0f172a;
      --card-bg: #1e293b;
      --text: #e2e8f0;
      --text-muted: #94a3b8;
      --accent: #38bdf8;
      --accent-hover: #0ea5e9;
      --modal-bg: #0b1120;
      --border: #334155;
      --shadow: 0 4px 6px -1px rgba(0,0,0,0.3), 0 2px 4px -1px rgba(0,0,0,0.2);
      --badge-free: #22c55e;
      --badge-trial: #f59e0b;
      --badge-paid: #ef4444;
      --filter-active: #38bdf8;
      --filter-bg: #1e293b;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      padding: 2rem 1rem;
    }

    header { text-align: center; margin-bottom: 2rem; }
    header h1 { font-size: 2.2rem; margin-bottom: 0.5rem; }
    header p { color: var(--text-muted); max-width: 650px; margin: 0 auto; }

    .legend {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      margin: 1.5rem 0;
      flex-wrap: wrap;
    }
    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.9rem;
      color: var(--text-muted);
    }
    .legend-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
    }
    .legend-dot.free { background: var(--badge-free); }
    .legend-dot.trial { background: var(--badge-trial); }
    .legend-dot.paid { background: var(--badge-paid); }

    .controls {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 1rem;
    }

    .search-box {
      width: 100%;
      max-width: 600px;
      margin: 0 auto 1.5rem;
      position: relative;
    }
    .search-box input {
      width: 100%;
      padding: 0.9rem 1.2rem 0.9rem 3rem;
      border: 2px solid var(--border);
      border-radius: 12px;
      background: var(--card-bg);
      color: var(--text);
      font-size: 1rem;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .search-box input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.1);
    }
    .search-box::before {
      content: "🔍";
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      font-size: 1.1rem;
    }

    .filters {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      justify-content: center;
      align-items: center;
      margin-bottom: 1rem;
    }
    .filter-group {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
    }
    .filter-label {
      font-size: 0.9rem;
      color: var(--text-muted);
      margin-right: 0.3rem;
    }
    .filter-btn {
      padding: 0.5rem 1rem;
      border: 2px solid var(--border);
      border-radius: 20px;
      background: var(--filter-bg);
      color: var(--text);
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.2s;
      font-weight: 500;
    }
    .filter-btn:hover {
      border-color: var(--accent);
      transform: translateY(-1px);
    }
    .filter-btn.active {
      background: var(--filter-active);
      color: #0f172a;
      border-color: var(--filter-active);
      font-weight: 600;
    }
    .clear-filters {
      padding: 0.5rem 1rem;
      border: 2px dashed var(--border);
      border-radius: 20px;
      background: transparent;
      color: var(--text-muted);
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .clear-filters:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .results-count {
      text-align: center;
      color: var(--text-muted);
      margin: 1rem 0;
      font-size: 0.95rem;
    }
    .results-count strong {
      color: var(--accent);
    }

    .section { 
      margin-bottom: 3.5rem;
      max-width: 1400px;
      margin-left: auto;
      margin-right: auto;
      padding: 0 1rem;
    }
    .section.hidden { display: none; }
    .section h2 {
      font-size: 1.6rem;
      margin-bottom: 0.5rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid var(--accent);
      display: inline-block;
    }
    .section .subtitle {
      color: var(--text-muted);
      margin-bottom: 1.5rem;
      font-size: 0.95rem;
    }

    .category-group { margin-bottom: 2.5rem; }
    .category-group.hidden { display: none; }
    .category-group h3 {
      font-size: 1.2rem;
      margin: 1.5rem 0 1rem;
      color: var(--accent);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .category-group h3:first-child { margin-top: 0; }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.5rem;
    }

    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      box-shadow: var(--shadow);
      transition: transform 0.2s, box-shadow 0.2s, opacity 0.3s;
      position: relative;
      animation: fadeIn 0.4s ease;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .card:hover { 
      transform: translateY(-4px); 
      box-shadow: 0 8px 12px rgba(0,0,0,0.4); 
    }
    .card.hidden { 
      display: none; 
    }
    .card h3 { 
      font-size: 1.25rem; 
      margin-bottom: 0.5rem; 
      color: var(--accent);
      padding-right: 5rem;
    }
    .card p { 
      color: var(--text-muted); 
      margin-bottom: 1rem; 
      font-size: 0.95rem; 
    }

    .badge {
      position: absolute;
      top: 1rem;
      right: 1rem;
      padding: 0.25rem 0.6rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
    }
    .badge.free { background: var(--badge-free); color: #052e16; }
    .badge.trial { background: var(--badge-trial); color: #431407; }
    .badge.paid { background: var(--badge-paid); color: #450a0a; }

    .btn {
      display: inline-block;
      background: var(--accent);
      color: #0f172a;
      border: none;
      padding: 0.6rem 1rem;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn:hover { background: var(--accent-hover); }

    .modal-overlay {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.75);
      backdrop-filter: blur(4px);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      padding: 1rem;
    }
    .modal-overlay.active { display: flex; }

    .modal {
      background: var(--modal-bg);
      border: 1px solid var(--border);
      border-radius: 14px;
      max-width: 620px;
      width: 100%;
      padding: 2rem;
      position: relative;
      max-height: 85vh;
      overflow-y: auto;
      animation: fadeIn 0.25s ease;
    }

    .modal h2 { color: var(--accent); margin-bottom: 0.5rem; }
    .modal .tags { display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .modal .tag {
      background: var(--border);
      padding: 0.2rem 0.6rem;
      border-radius: 20px;
      font-size: 0.8rem;
      color: var(--text-muted);
    }
    .modal .price-tag {
      background: var(--badge-free);
      color: #052e16;
      font-weight: 600;
    }
    .modal .price-tag.trial { background: var(--badge-trial); color: #431407; }
    .modal .price-tag.paid { background: var(--badge-paid); color: #450a0a; }

    .modal p { margin-bottom: 1rem; }
    .modal .limits {
      background: rgba(56, 189, 248, 0.1);
      border-left: 3px solid var(--accent);
      padding: 0.8rem;
      border-radius: 0 8px 8px 0;
      margin-bottom: 1rem;
      font-size: 0.9rem;
      line-height: 1.5;
    }
    .modal .link {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
    }
    .modal .link:hover { text-decoration: underline; }

    .close-btn {
      position: absolute;
      top: 1rem; right: 1rem;
      background: transparent;
      border: none;
      color: var(--text-muted);
      font-size: 1.5rem;
      cursor: pointer;
      line-height: 1;
    }
    .close-btn:hover { color: var(--accent); }

    .tip-box {
      background: #111827;
      border: 1px dashed var(--accent);
      border-radius: 12px;
      padding: 1.5rem;
      margin: 3rem auto;
      max-width: 800px;
    }
    .tip-box h3 { color: var(--accent); margin-bottom: 0.5rem; }
    .tip-box code {
      background: #1e293b;
      padding: 0.2rem 0.4rem;
      border-radius: 4px;
      font-family: ui-monospace, monospace;
      font-size: 0.9em;
    }
    .tip-box pre {
      background: #0b1120;
      padding: 1rem;
      border-radius: 8px;
      overflow-x: auto;
      margin-top: 0.8rem;
      font-size: 0.85rem;
      line-height: 1.5;
      color: #cbd5e1;
    }

    footer {
      text-align: center;
      margin-top: 3rem;
      color: var(--text-muted);
      font-size: 0.85rem;
    }

    @media (max-width: 768px) {
      .modal { padding: 1.5rem; }
      header h1 { font-size: 1.8rem; }
      .legend { flex-direction: column; align-items: center; gap: 0.5rem; }
      .filters { flex-direction: column; }
      .filter-group { width: 100%; justify-content: center; }
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
