      { id: "cursor", name: "Cursor", category: "programacion", priceModel: "trial", short: "Editor de código con IA (VS Code fork).", full: "IDE moderno con autocompletado inteligente y chat.", limits: "~20-50 completions/mes free. Pro $20/mes.", url: "https://cursor.com" },
      { id: "gamma", name: "Gamma.app", category: "productividad", priceModel: "trial", short: "Presentaciones y documentos con IA.", full: "Genera decks profesionales automáticamente.", limits: "400 créditos iniciales. Pago $10-20/mes.", url: "https://gamma.app" },
      { id: "notebooklm", name: "NotebookLM", category: "investigacion", priceModel: "trial", short: "Analiza documentos con IA (Google).", full: "Sube PDFs y obtén resúmenes con fuentes.", limits: "50 fuentes/notebook, 500k palabras.", url: "https://notebooklm.google.com" },

      // ====== 🔴 PAGAS ======
      { id: "midjourney", name: "Midjourney", category: "imagenes-video", priceModel: "paid", short: "Imágenes artísticas de alta calidad.", full: "Líder en generación artística y fotorealismo.", limits: "Sin plan free. Desde $10/mes.", url: "https://midjourney.com" },
      { id: "jasper", name: "Jasper", category: "escritura", priceModel: "paid", short: "Copywriting y contenido marketing.", full: "Especializado en SEO, blogs y anuncios.", limits: "7 días trial. Desde $49/mes.", url: "https://jasper.ai" },
      { id: "runway", name: "Runway ML", category: "imagenes-video", priceModel: "paid", short: "Edición de video profesional con IA.", full: "Generación de video, rotoscopia, efectos.", limits: "Free muy limitado. Standard $15/mes.", url: "https://runwayml.com" },
      { id: "copy-ai", name: "Copy.ai", category: "escritura", priceModel: "paid", short: "Contenido para e-commerce.", full: "Descripciones de producto, emails, ads.", limits: "2000 palabras/mes free. Desde $49/mes.", url: "https://copy.ai" }
    ];

    const categories = {
      general: "🌐 Generales / Multimodales",
      "imagenes-video": "🎨 Imágenes & Video",
      "audio-musica": "🎵 Audio & Música",
      programacion: "💻 Programación & Código",
      "social-media": "📱 Redes Sociales",
      productividad: "⚡ Productividad",
      investigacion: "🔍 Investigación",
      escritura: "✍️ Escritura & Copy",
      "personajes-3d": "🎭 3D & Personajes"
    };

    const priceGroups = [
      { key: "free", title: "🟢 100% Gratuitas", subtitle: "Sin costo, sin tarjeta, uso ilimitado o con límites generosos." },
      { key: "trial", title: "🟡 Prueba Gratuita (Trial)", subtitle: "Acceso temporal o con límites muy restrictivos. Requiere pago para uso continuo." },
      { key: "paid", title: "🔴 De Pago", subtitle: "Sin plan gratuito viable. Inversión profesional para resultados premium." }
    ];

    let currentFilters = { search: "", price: "all", category: "all" };
    const app = document.getElementById('app');

    function renderTools() {
      app.innerHTML = '';
      let totalVisible = 0;

      priceGroups.forEach(group => {
        const toolsInGroup = aiTools.filter(t => t.priceModel === group.key);
        if (toolsInGroup.length === 0) return;

        const section = document.createElement('section');
        section.className = 'section';
        section.id = `section-${group.key}`;
        section.innerHTML = `<h2>${group.title}</h2><p class="subtitle">${group.subtitle}</p><div id="container-${group.key}"></div>`;
        app.appendChild(section);

        const container = document.getElementById(`container-${group.key}`);
        const toolsByCategory = {};
        toolsInGroup.forEach(tool => {
          if (!toolsByCategory[tool.category]) toolsByCategory[tool.category] = [];
          toolsByCategory[tool.category].push(tool);
        });

        let categoryVisibleCount = 0;

        Object.entries(toolsByCategory).forEach(([catKey, tools]) => {
          const catGroup = document.createElement('div');
          catGroup.className = 'category-group';
          catGroup.id = `cat-${group.key}-${catKey}`;
          catGroup.innerHTML = `<h3>${categories[catKey] || catKey}</h3><div class="grid"></div>`;
          const grid = catGroup.querySelector('.grid');
          let toolsInCatVisible = 0;

          tools.forEach(tool => {
            const matchesSearch = !currentFilters.search || 
              tool.name.toLowerCase().includes(currentFilters.search.toLowerCase()) ||
              tool.short.toLowerCase().includes(currentFilters.search.toLowerCase()) ||
              tool.full.toLowerCase().includes(currentFilters.search.toLowerCase());
            
            const matchesPrice = currentFilters.price === 'all' || tool.priceModel === currentFilters.price;
            const matchesCategory = currentFilters.category === 'all' || tool.category === currentFilters.category;

            const card = document.createElement('div');
            card.className = 'card';
            card.dataset.id = tool.id;
            
            if (!matchesSearch || !matchesPrice || !matchesCategory) {
              card.classList.add('hidden');
            } else {
              toolsInCatVisible++;
              categoryVisibleCount++;
              totalVisible++;
            }

            const badgeClass = tool.priceModel;
            card.innerHTML = `
              <span class="badge ${badgeClass}">${tool.priceModel === 'free' ? 'Gratis' : tool.priceModel === 'trial' ? 'Trial' : 'Pago'}</span>
              <h3>${tool.name}</h3>
              <p>${tool.short}</p>
              <button class="btn" data-id="${tool.id}">📖 Detalles</button>
            `;
            grid.appendChild(card);
          });
          
          if (toolsInCatVisible === 0) catGroup.classList.add('hidden');
          container.appendChild(catGroup);
        });

        if (categoryVisibleCount === 0) section.classList.add('hidden');
      });

      const resultsCount = document.getElementById('resultsCount');
      if (totalVisible === 0) {
        resultsCount.innerHTML = '<div class="no-results">😕 No se encontraron herramientas</div>';
      } else {
        resultsCount.innerHTML = `Mostrando <strong>${totalVisible}</strong> de <strong>${aiTools.length}</strong> herramientas`;
      }

      document.querySelectorAll('.btn').forEach(btn => {
        btn.addEventListener('click', e => openModal(e.target.dataset.id));
      });
    }

    const overlay = document.getElementById('modalOverlay');
    const modalTitle = document.getElementById('modalTitle');
    const modalCategory = document.getElementById('modalCategory');
    const modalPrice = document.getElementById('modalPrice');
    const modalDesc = document.getElementById('modalDesc');
    const modalLimits = document.getElementById('modalLimits');
    const modalLink = document.getElementById('modalLink');

    const priceLabels = { free: "✅ 100% Gratis", trial: "🟡 Prueba Gratuita", paid: "🔴 De Pago" };
    const priceClass = { free: "", trial: "trial", paid: "paid" };

    function openModal(id) {
      const tool = aiTools.find(t => t.id === id);
      if (!tool) return;
      modalTitle.textContent = tool.name;
      modalCategory.textContent = categories[tool.category] || tool.category;
      modalPrice.textContent = priceLabels[tool.priceModel];
      modalPrice.className = `tag price-tag ${priceClass[tool.priceModel]}`;
      modalDesc.textContent = tool.full;
      modalLimits.innerHTML = `<strong>ℹ️ Condiciones:</strong><br>${tool.limits}`;
      modalLink.href = tool.url;
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    }

    document.getElementById('searchInput').addEventListener('input', e => {
      currentFilters.search = e.target.value.trim();
      renderTools();
    });

    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        currentFilters[btn.dataset.filter] = btn.dataset.value;
        document.querySelectorAll(`.filter-btn[data-filter="${btn.dataset.filter}"]`).forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderTools();
      });
    });

    document.getElementById('clearFilters').addEventListener('click', () => {
      currentFilters = { search: "", price: "all", category: "all" };
      document.getElementById('searchInput').value = "";
      document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.value === 'all');
      });
      renderTools();
    });

    document.querySelector('.close-btn').addEventListener('click', closeModal);
    overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

    renderTools();
  </script>
</body>
</html>